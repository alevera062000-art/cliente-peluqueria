# ─────────────────────────────────────────────────────────────
# BN Estilistas — variables de entorno
# Copia este archivo a .env.local para desarrollo y configura los
# mismos valores en el dashboard de Vercel (Project Settings → Environment Variables).
# ─────────────────────────────────────────────────────────────

# URL pública del sitio (usada en canonical, Open Graph, JSON-LD, robots.txt y sitemap.xml).
NEXT_PUBLIC_SITE_URL=https://www.bnestilistas.com

# ── Firebase (cliente) ──────────────────────────────────────────
# Estos valores son públicos por diseño (la seguridad real la dan las reglas
# de la Realtime Database), pero NO deben quedar hardcodeados en el código fuente.
# Sácalos de: Firebase Console → Configuración del proyecto → General → Tus apps → SDK setup.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firebase Admin (solo servidor — usado por /api/admin) ──────
# JSON completo de la cuenta de servicio (Firebase Console → Configuración del
# proyecto → Cuentas de servicio → Generar nueva clave privada), como una sola
# línea de texto (todo el JSON entre comillas simples si lo pegas en .env.local).
FIREBASE_SERVICE_ACCOUNT=

# ── Panel de administración ─────────────────────────────────────
# Contraseña que valida el servidor en /api/admin (header x-admin-pass).
ADMIN_PASSWORD=

# ── Chatbot IA (solo servidor — usado por /api/chat) ────────────
GEMINI_API_KEY=

# ── Recordatorio diario programado (solo servidor — /api/cron/daily-reminder) ──
CALLMEBOT_PHONE=
CALLMEBOT_APIKEY=
RESEND_API_KEY=
# Secreto que Vercel Cron envía automáticamente como "Authorization: Bearer <valor>"
# si esta variable existe — protege el endpoint de peticiones públicas no autorizadas.
CRON_SECRET=

# ── EmailJS (cliente, opcional) ──────────────────────────────────
# Deja en blanco para mantener el envío de factura por email desactivado,
# igual que en el sitio actual (EMAIL_CONFIG no está configurado todavía).
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_CLIENTE=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ADMIN=
NEXT_PUBLIC_EMAILJS_BUSINESS_EMAIL=
